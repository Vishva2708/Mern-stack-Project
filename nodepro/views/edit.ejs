<!DOCTYPE html>
<html>
<head>
    <title>Edit Collection</title>
</head>
<body>

    <h2>Edit Collection</h2>

   <form action="/collections/update/<%= data._id %>" 
      method="POST" 
      enctype="multipart/form-data">


        <label>Title:</label><br>
        <input type="text" name="title" value="<%= data.title %>" required>
        <br><br>

        <label>Category:</label><br>
        <input type="text" name="category" value="<%= data.category %>" required>
        <br><br>

        <label>Price:</label><br>
        <input type="number" name="price" value="<%= data.price %>" required>
        <br><br>

        <label>Brand:</label><br>
        <input type="text" name="brand" value="<%= data.brand %>" required>
        <br><br>

         <label>Discription:</label><br>
        <input type="text" name="discription" value="<%= data.discription%>" required>
        <br><br>

        <label>Old Image:</label><br>
        <img src="/upload/<%= data.image %>" width="120">
        <br><br>

        <label>Change Image:</label><br>
        <input type="file" name="image">
        <br><br>

        <button type="submit">Update</button>

    </form>

</body>
</html>
