<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>

    <h1>Edit Category</h1>

    <form
    action="/categories/update/<%= data._id %>"
    method="post"
    enctype="multipart/form-data"
    >

        <input
        type="text"
        name="category"
        value="<%= data.category %>"
        >

        <input
        type="text"
        name="brand"
        value="<%= data.brand %>"
        >

        <input
        type="text"
        name="title"
        value="<%= data.title %>"
        >

        <input
        type="text"
        name="price"
        value="<%= data.price %>"
        >

        <input type="file" name="image">

        <button type="submit">
            Update
        </button>

    </form>

</body>
</html>